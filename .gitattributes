# Normalise line endings to LF in the repository, so Prettier
# (endOfLine: "lf", enforced by `npm run format:check`), ruff, Quarto and the
# rest of the tooling agree regardless of a contributor's core.autocrlf setting
# or editor (e.g. GitHub Desktop on Windows).
* text=auto

# Source and config — always LF
*.py        text eol=lf
*.qmd       text eol=lf
*.md        text eol=lf
*.bib       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf
*.cff       text eol=lf
*.tex       text eol=lf
*.csl       text eol=lf
*.dot       text eol=lf
*.sh        text eol=lf
*.ipynb     text eol=lf

# Binary — do not modify
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.svg       binary
*.pdf       binary
*.docx      binary
*.duckdb    binary
*.nc        binary
